# --------------------------------------------------
dist/
*.apk
*.aab
*.ipa
*.exe
*.msix
*.msixbundle
*.dmg
*.app
*.deb
*.rpm

# --------------------------------------------------
# Claude Code (AI config, rules, hooks, skills - local only)
# --------------------------------------------------
.claude/
!.claude/
.claude/*
!.claude/rules/
!.claude/rules/*.md
.agent/
.agents/
skills-lock.json

# --------------------------------------------------
# AI Tool Artifacts (local only - NOT for version control)
# --------------------------------------------------
.codex/
.superpowers/
docs/superpowers/
.playwright-mcp/

# --------------------------------------------------
# MCP Server Config (contains API tokens - NEVER commit)
# --------------------------------------------------
.mcp.json
.mcp.local.json

# --------------------------------------------------
# Output / Build Artifacts
# --------------------------------------------------
output/
build_log.txt
failing_tests.log
flutter_*.log
scr_test.log
*.coverage
.coverage
coverage_report.html

# --------------------------------------------------
# Temporary / CI artifacts
# --------------------------------------------------
tmp/

# --------------------------------------------------
# Root-level screenshots / images (dev & debug artifacts)
# --------------------------------------------------
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp

# --------------------------------------------------
# Supabase Edge Functions - Node artifacts
# --------------------------------------------------
supabase/functions/node_modules/
supabase/functions/**/node_modules/
supabase/functions/**/*.js.map

