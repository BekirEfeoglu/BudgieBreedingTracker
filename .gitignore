# ============================================================
# BudgieBreedingTracker - .gitignore
# Cross-Platform: Windows + macOS | Flutter + Dart
# ============================================================

# --------------------------------------------------
# macOS
# --------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
*.swp
.AppleDouble
.LSOverride
Icon?
!web/icons/
!assets/icons/
!test/features/icons/

# --------------------------------------------------
# Windows
# --------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
*.lnk
[Dd]esktop.ini
$RECYCLE.BIN/

# --------------------------------------------------
# IDE - VS Code
# --------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# --------------------------------------------------
# IDE - IntelliJ / Android Studio
# --------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.idea_modules/
atlassian-ide-plugin.xml

# --------------------------------------------------
# Flutter / Dart
# --------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
.metadata

# Generated files (build_runner re-generates on CI)
*.g.dart
*.freezed.dart
*.mocks.dart
*.config.dart
*.gr.dart
lib/generated_plugin_registrant.dart

# Drift (SQLite) generated files
*.drift.dart
lib/**/*.drift.dart

# Coverage
coverage/
.test_coverage/

# --------------------------------------------------
# Platform - Android
# --------------------------------------------------
android/.gradle/
android/captures/
android/gradlew
android/gradlew.bat
android/local.properties
android/**/GeneratedPluginRegistrant.java
android/**/GeneratedPluginRegistrant.kt
android/key.properties
android/**/*.keystore
android/**/*.jks
!android/gradle/wrapper/gradle-wrapper.jar

# --------------------------------------------------
# Platform - iOS
# --------------------------------------------------
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
ios/Flutter/app.flx
ios/Flutter/app.zip
ios/Flutter/flutter_assets/
ios/ServiceDefinitions.json
ios/Runner/GeneratedPluginRegistrant.*

# --------------------------------------------------
# Platform - Windows
# --------------------------------------------------
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugin_registrant.h
windows/flutter/generated_plugins.cmake
windows/flutter/ephemeral/

# --------------------------------------------------
# Platform - macOS
# --------------------------------------------------
macos/Flutter/GeneratedPluginRegistrant.swift
macos/Flutter/ephemeral/
macos/Pods/

# --------------------------------------------------
