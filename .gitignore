# --------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.p12
*.key
secrets/
config/local_config.dart
ios/Flutter/DartDefines.xcconfig
ios/Flutter/Env.xcconfig
lib/config/supabase_config.dart

