# Supabase Configuration (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Sentry Error Tracking (Optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# RevenueCat In-App Purchases (Optional)
# Client SDK keys — these ship in the app binary, public by design.
REVENUECAT_API_KEY_IOS=
REVENUECAT_API_KEY_ANDROID=
# NOTE: REVENUECAT_SECRET_API_KEY is server-side only.
# Do NOT add it here — store it as a Supabase Edge Function secret
# (Dashboard -> Edge Functions -> Secrets) so it never reaches the client.

# Google OAuth Client IDs
# As of 2026-05-26 the OAuth clients live in the Firebase project
# (number 720334450619). Supabase Auth still accepts the legacy
# project's IDs (multi-audience configured) so older binaries keep
# working during rollout. Use the new IDs for fresh builds:
#   GOOGLE_WEB_CLIENT_ID=720334450619-kvo5m738euj98t4qmmqeabmmd48ma0tl.apps.googleusercontent.com
#   GOOGLE_IOS_CLIENT_ID=720334450619-oacalc9gn0sg986d16it34jr4th6bkf4.apps.googleusercontent.com
# See .claude/rules/security.md § Google Sign-In OAuth Topology.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Edge Function Providers (Optional but required for image safety scanning)
OPENAI_API_KEY=

# Firebase Push Notifications
FIREBASE_PROJECT_ID=
