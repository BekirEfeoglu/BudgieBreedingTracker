# Supabase Configuration (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Sentry Error Tracking (Optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# RevenueCat In-App Purchases (Optional)
# Client SDK keys — these ship in the app binary, public by design.
REVENUECAT_API_KEY_IOS=
REVENUECAT_API_KEY_ANDROID=
# NOTE: REVENUECAT_SECRET_API_KEY is server-side only.
# Do NOT add it here — store it as a Supabase Edge Function secret
# (Dashboard -> Edge Functions -> Secrets) so it never reaches the client.

# Google OAuth Client IDs (Optional)
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Edge Function Providers (Optional but required for image safety scanning)
OPENAI_API_KEY=

# Firebase Push Notifications
FIREBASE_PROJECT_ID=
