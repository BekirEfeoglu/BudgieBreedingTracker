# ============================================================
# BudgieBreedingTracker - .gitattributes
# Cross-Platform Line Ending & Binary File Management
# ============================================================

# Varsayılan: Tüm text dosyaları LF'e normalleştirilir
* text=auto eol=lf

# --------------------------------------------------
# Dart / Flutter
# --------------------------------------------------
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.arb text eol=lf
pubspec.lock text eol=lf

# --------------------------------------------------
# Web
# --------------------------------------------------
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf

# --------------------------------------------------
# Config & Scripts
# --------------------------------------------------
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.plist text eol=lf
*.pbxproj text eol=lf
*.xcscheme text eol=lf
*.swift text eol=lf
*.kt text eol=lf
*.java text eol=lf
*.h text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.cmake text eol=lf
*.sh text eol=lf
*.sql text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# --------------------------------------------------
# Windows-specific dosyalar (CRLF kalmalı)
# --------------------------------------------------
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.sln text eol=crlf
*.vcxproj text eol=crlf
*.rc text eol=crlf

# --------------------------------------------------
# Binary dosyalar (dokunulmamalı)
# --------------------------------------------------
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text eol=lf
*.bmp binary

# Fontlar
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Ses
*.mp3 binary
*.wav binary
*.ogg binary

# Veritabanı
*.db binary
*.sqlite binary
*.sqlite3 binary

# Paketler / Arşivler
*.zip binary
*.tar.gz binary
*.jar binary
*.aar binary

# Platform binary
*.exe binary
*.dll binary
*.dylib binary
*.so binary
*.framework binary

# Sertifikalar
*.keystore binary
*.jks binary
*.p12 binary
*.pem binary

# --------------------------------------------------
# Git LFS (büyük asset'ler için - isteğe bağlı)
# --------------------------------------------------
# Aşağıdakileri aktif etmek için 'git lfs install' çalıştır
# *.psd filter=lfs diff=lfs merge=lfs -text
# *.ai filter=lfs diff=lfs merge=lfs -text
# assets/**/*.png filter=lfs diff=lfs merge=lfs -text

# --------------------------------------------------
# Linguist - GitHub dil istatistikleri
# --------------------------------------------------
*.g.dart linguist-generated=true
*.freezed.dart linguist-generated=true
*.drift.dart linguist-generated=true
*.mocks.dart linguist-generated=true
