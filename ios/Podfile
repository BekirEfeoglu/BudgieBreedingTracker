# google_mobile_ads 7.x requires iOS 14.0+
# supabase_flutter, flutter_secure_storage, app_links: iOS 13.0+
# Using 14.0 to satisfy the highest minimum requirement across all pods.
platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

# Suppress warning noise coming from third-party pods (plugin code in .pub-cache).
# This keeps app build logs focused on warnings from our own source files.
inhibit_all_warnings!

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig and running flutter pub get again."
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    # Ensure all pods respect the minimum iOS deployment target.
    # Required when pods declare a lower minimum than the platform setting.
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
      config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'
      # Strip simulator architectures from release builds to pass App Store validation.
      # Fixes: "executable references an unsupported platform in the arm64 slice"
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
    end
  end

  # Strip simulator platform metadata from embedded frameworks (objective_c, etc.)
  strip_simulator_script = <<~SCRIPT
    # Remove simulator platform references from frameworks for App Store submission
    find "${BUILT_PRODUCTS_DIR}" -name '*.framework' -type d | while read -r framework; do
      binary="$(basename "$framework" .framework)"
      binary_path="$framework/$binary"
      if [ -f "$binary_path" ]; then
        # Check if binary contains simulator slice
        if lipo -info "$binary_path" 2>/dev/null | grep -q "x86_64"; then
          lipo -remove x86_64 "$binary_path" -output "$binary_path" 2>/dev/null || true
        fi
      fi
    done
  SCRIPT

  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      if config.name == 'Release' || config.name == 'Profile'
        config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
      end
    end
  end
end
