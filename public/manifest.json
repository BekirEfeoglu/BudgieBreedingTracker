{
  "name": "BudgieBreedingTracker",
  "short_name": "BudgieBreedingTracker",
  "description": "Muhabbet kuşu üretim takip uygulaması - Kuluçka, yumurta ve yavru yönetimi",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#10b981",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "tr",
  "dir": "ltr",
  "categories": ["lifestyle", "productivity", "utilities"],
  "icons": [
    {
      "src": "/icons/icon-192x192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-512x512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable any"
    }
  ],
  "shortcuts": [
    {
      "name": "Yeni Kuş Ekle",
      "short_name": "Kuş Ekle",
      "description": "Yeni muhabbet kuşu ekle",
      "url": "/?action=add-bird",
      "icons": [
        {
          "src": "/icons/shortcut-add-bird.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Üreme Başlat",
      "short_name": "Üreme",
      "description": "Yeni üreme döngüsü başlat",
      "url": "/?action=start-breeding",
      "icons": [
        {
          "src": "/icons/shortcut-breeding.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Yumurta Takibi",
      "short_name": "Yumurta",
      "description": "Yumurta durumunu kontrol et",
      "url": "/?action=egg-tracking",
      "icons": [
        {
          "src": "/icons/shortcut-eggs.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Analytics",
      "short_name": "Analytics",
      "description": "Performans raporlarını görüntüle",
      "url": "/?action=analytics",
      "icons": [
        {
          "src": "/icons/shortcut-analytics.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/desktop-main.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Ana sayfa - Masaüstü görünümü"
    },
    {
      "src": "/screenshots/mobile-main.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Ana sayfa - Mobil görünümü"
    },
    {
      "src": "/screenshots/breeding-tracking.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Üreme takibi"
    },
    {
      "src": "/screenshots/analytics.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Analytics dashboard"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "protocol_handlers": [
    {
      "protocol": "web+budgie",
      "url": "/?action=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/?action=import-data",
      "accept": {
        "application/json": [".json"],
        "text/csv": [".csv"]
      }
    }
  ],
  "share_target": {
    "action": "/?action=share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["image/*", "application/json"]
        }
      ]
    }
  },
  "permissions": [
    "notifications",
    "background-sync",
    "storage",
    "camera",
    "microphone"
  ],
  "features": [
    "Cross Platform",
    "Offline Support",
    "Push Notifications",
    "Background Sync",
    "File Upload",
    "Data Export",
    "Real-time Updates",
    "Mobile Optimized",
    "PWA Support"
  ]
} 